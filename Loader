            end
            continue
        end

        local humanoidC = charC:FindFirstChild("Humanoid")
        local rootC = charC.PrimaryPart or charC:FindFirstChild("HumanoidRootPart")

        if not arrowObjects[player] then
            arrowObjects[player] = Drawing.new("Triangle")
            arrowObjects[player].Visible = false
            arrowObjects[player].Filled = true
            arrowObjects[player].Thickness = 1
            arrowObjects[player].Transparency = 1

            arrowOutlines[player] = createArrowOutlines()
        end

        local arrow = arrowObjects[player]
        local outlines = arrowOutlines[player]

        if not arrowOn or not rootC or not myRoot2 or not humanoidC or humanoidC.Health <= 0 then
            arrow.Visible = false
            if outlines then
                for _, line in ipairs(outlines) do line.Visible = false end
            end
            continue
        end

        local dist3D = (myRoot2.Position - rootC.Position).Magnitude
        if dist3D > maxDist then
            arrow.Visible = false
            if outlines then
                for _, line in ipairs(outlines) do line.Visible = false end
            end
            continue
        end

        local _, onScreen = Camera:WorldToViewportPoint(rootC.Position)
        if onScreen then
            arrow.Visible = false
