-- CROSSHAIR RENDER STEP (WITH PROPER STYLE SWITCHING)
-- ============================================================
RunService.RenderStepped:Connect(function(dt)
    if not (Toggles.CrosshairEnabled and Toggles.CrosshairEnabled.Value) then
        -- Hide everything
        for i = 1, 4 do
            if chLines[i] then chLines[i].Visible = false end
            if chOutlines[i] then chOutlines[i].Visible = false end
            if chFlapLines[i] then chFlapLines[i].Visible = false end
            if chFlapOutlines[i] then chFlapOutlines[i].Visible = false end
        end
        for i = 1, 6 do
            if chStarLines[i] then chStarLines[i].Visible = false end
            if chStarOutlines[i] then chStarOutlines[i].Visible = false end
        end
        if chDot then chDot.Visible = false end
        if chDotOutline then chDotOutline.Visible = false end
        return
    end

    local styleName = Options.CrosshairStyle and Options.CrosshairStyle.Value or "Cross"
    local size = Options.CrosshairSize and Options.CrosshairSize.Value or 10
    local gap = Options.CrosshairGap and Options.CrosshairGap.Value or 3
    local thickness = Options.CrosshairThickness and Options.CrosshairThickness.Value or 2
    local color = Options.CrosshairColor and Options.CrosshairColor.Value or Color3.fromRGB(255,255,255)
    local showOutline = Toggles.CrosshairOutline and Toggles.CrosshairOutline.Value
    local posMode = Options.CrosshairPositionMode and Options.CrosshairPositionMode.Value or "Mouse"
    local lockOn = Toggles.CrosshairLockOnTarget and Toggles.CrosshairLockOnTarget.Value

    -- Spin
    if Toggles.CrosshairSpin and Toggles.CrosshairSpin.Value then
        local spd = Options.CrosshairSpinSpeed and Options.CrosshairSpinSpeed.Value or 90
        chAngle = (chAngle + dt * spd) % 360
    end

    -- Get center position
    local center
    if lockOn and locked_player then
        local ok, model = pcall(function() return getModel:Invoke(locked_player) end)
        if ok and model then
            local headLock = Toggles.HeadLock and Toggles.HeadLock.Value
            local part = headLock and (model:FindFirstChild("Head") or model.PrimaryPart) or (model:FindFirstChild("Torso") or model.PrimaryPart)
            if part then
                local sp, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local target = Vector2.new(sp.X, sp.Y)
                    chCurrentOrigin = chCurrentOrigin:Lerp(target, 0.35)
                    center = chCurrentOrigin
                end
            end
        end
    end
    if not center then
        if posMode == "Center Of Screen" then
            local vs = Camera.ViewportSize
            center = Vector2.new(vs.X/2, vs.Y/2)
        else
            center = UserInputService:GetMouseLocation()
        end
        chCurrentOrigin = center
    end

    -- Hide all elements initially
    for i = 1, 4 do
        if chLines[i] then chLines[i].Visible = false end
        if chOutlines[i] then chOutlines[i].Visible = false end
        if chFlapLines[i] then chFlapLines[i].Visible = false end
        if chFlapOutlines[i] then chFlapOutlines[i].Visible = false end
    end
    for i = 1, 6 do
        if chStarLines[i] then chStarLines[i].Visible = false end
        if chStarOutlines[i] then chStarOutlines[i].Visible = false end
    end
    if chDot then chDot.Visible = false end
    if chDotOutline then chDotOutline.Visible = false end

    -- ========== STYLE: Dot ==========
    if styleName == "Dot" then
        local dotRadius = math.max(1, math.floor(thickness * 1.5))
        if showOutline then
            chDotOutline.Radius = dotRadius + 1
            chDotOutline.Position = center
            chDotOutline.Visible = true
        end
        chDot.Radius = dotRadius
        chDot.Position = center
        chDot.Color = color
        chDot.Visible = true
        return
    end

    -- ========== STYLE: Star ==========
    if styleName == "Star" then
        local R = size
        local triAngles = {{90,210,330}, {270,30,150}}
        local lineIdx = 1
        for _, tri in ipairs(triAngles) do
            local verts = {}
            for j = 1, 3 do
                local rad = math.rad(chAngle + tri[j])
                verts[j] = center + Vector2.new(math.cos(rad), -math.sin(rad)) * R
            end
            for j = 1, 3 do
                local a = verts[j]
                local b = verts[(j % 3) + 1]
                if showOutline and chStarOutlines[lineIdx] then
                    chStarOutlines[lineIdx].From = a
                    chStarOutlines[lineIdx].To = b
                    chStarOutlines[lineIdx].Thickness = thickness + 2
                    chStarOutlines[lineIdx].Visible = true
                end
                if chStarLines[lineIdx] then
                    chStarLines[lineIdx].From = a
                    chStarLines[lineIdx].To = b
                    chStarLines[lineIdx].Color = color
                    chStarLines[lineIdx].Thickness = thickness
                    chStarLines[lineIdx].Visible = true
                end
                lineIdx = lineIdx + 1
            end
        end
        return
    end

    -- ========== STYLE: Circle ==========
    if styleName == "Circle" then
        if showOutline then
            chDotOutline.Radius = size + 1
            chDotOutline.Position = center
            chDotOutline.Filled = false
            chDotOutline.Thickness = thickness + 2
            chDotOutline.NumSides = 32
            chDotOutline.Visible = true
        end
        chDot.Radius = size
        chDot.Position = center
        chDot.Color = color
        chDot.Filled = false
        chDot.Thickness = thickness
        chDot.NumSides = 32
        chDot.Visible = true
        return
    end

    -- ========== STYLE: X (45-degree rotated cross) ==========
    if styleName == "X" then
        local angles = {45, 135, 225, 315}
        for i = 1, 4 do
            local rad = math.rad(chAngle + angles[i])
            local dir = Vector2.new(math.cos(rad), math.sin(rad))
            local from = center + dir * gap
            local to = center + dir * (gap + size)
            
            if showOutline and chOutlines[i] then
                chOutlines[i].From = from
                chOutlines[i].To = to
                chOutlines[i].Thickness = thickness + 2
                chOutlines[i].Visible = true
            end
            if chLines[i] then
                chLines[i].From = from
                chLines[i].To = to
                chLines[i].Color = color
                chLines[i].Thickness = thickness
                chLines[i].Visible = true
            end
        end
        return
    end

    -- ========== STYLE: T-Shape ==========
    if styleName == "T-Shape" then
        -- Draw all 4 directions with T-bars, main line starts at center
        for i = 1, 4 do
            local rad = math.rad(chAngle + ANGLES[i])
            local dir = Vector2.new(math.cos(rad), math.sin(rad))
            local from = center
            local to = center + dir * (gap + size)
            
            -- Outline
            if showOutline and chOutlines[i] then
                chOutlines[i].From = from
                chOutlines[i].To = to
                chOutlines[i].Thickness = thickness + 2
                chOutlines[i].Visible = true
            end
            -- Main line
            if chLines[i] then
                chLines[i].From = from
                chLines[i].To = to
                chLines[i].Color = color
                chLines[i].Thickness = thickness
                chLines[i].Visible = true
            end
            
            -- T-bar
            local perp = Vector2.new(-dir.Y, dir.X)
            local offset = math.max(2, size)
