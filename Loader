                if enabled then
                    if not originalHitboxSizes[part] then originalHitboxSizes[part]=part.Size; originalHitboxProps[part]={Transparency=part.Transparency,Color=part.Color,Material=part.Material} end
                    part.Size=Vector3.new(size,size,size); part.Transparency=transparency; part.Color=color
