            if showOutline and chFlapOutlines[i] then
                chFlapOutlines[i].From = to
                chFlapOutlines[i].To = flapTo
                chFlapOutlines[i].Thickness = thickness + 2
                chFlapOutlines[i].Visible = true
            end
            if chFlapLines[i] then
                chFlapLines[i].From = to
                chFlapLines[i].To = flapTo
                chFlapLines[i].Color = color
                chFlapLines[i].Thickness = thickness
                chFlapLines[i].Visible = true
            end
        end
        return
    end

    -- ========== STYLE: Cross (default) ==========
    -- Full cross with all 4 lines
    for i = 1, 4 do
        local rad = math.rad(chAngle + ANGLES[i])
        local dir = Vector2.new(math.cos(rad), math.sin(rad))
        local from = center + dir * gap
        local to = center + dir * (gap + size)
        
        if showOutline and chOutlines[i] then
            chOutlines[i].From = from
            chOutlines[i].To = to
            chOutlines[i].Thickness = thickness + 2
            chOutlines[i].Visible = true
        end
        if chLines[i] then
            chLines[i].From = from
            chLines[i].To = to
            chLines[i].Color = color
            chLines[i].Thickness = thickness
            chLines[i].Visible = true
        end
    end
end)

