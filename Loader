local TRACER_TEXTURES = {
    ["1"]="rbxthumb://type=Asset&id=7151778311&w=420&h=420",
    ["2"]="rbxthumb://type=Asset&id=446111271&w=420&h=420",
    ["3"]="rbxthumb://type=Asset&id=86406621856457&w=420&h=420",
    ["4"]="rbxthumb://type=Asset&id=7151842833&w=420&h=420",
    ["5"]="rbxthumb://type=Asset&id=15000399181&w=420&h=420",
    ["6"]="rbxthumb://type=Asset&id=73663492833517&w=420&h=420",
}

local function drawTracer(origin, direction)
    -- resolve endpoint
    local endPos
    if direction then
        pcall(function()
            local myModel=getModel:Invoke(LocalPlayer)
            local params=RaycastParams.new(); params.FilterDescendantsInstances={myModel,Camera}
            params.FilterType=Enum.RaycastFilterType.Exclude; params.RespectCanCollide=false
            local result=workspace:Raycast(origin,direction*2500,params)
            endPos=result and result.Position or (origin+direction*2500)
        end)
        if not endPos then endPos=origin+direction*2500 end
    else
        endPos=origin+Vector3.new(0,0,-100)
    end

    local tracerColor = Options.TracerColor and Options.TracerColor.Value or Color3.fromRGB(0,255,255)
    local diameter    = (Options.TracerSize and Options.TracerSize.Value or 1) * 0.1
    local duration    = Options.TracerLifetime and Options.TracerLifetime.Value or 4
    local texSpeed    = Options.TracerAnimSpeed and Options.TracerAnimSpeed.Value or 3
    local style       = Options.TracerStyle and Options.TracerStyle.Value or "1"
    local textureId   = TRACER_TEXTURES[style] or TRACER_TEXTURES["1"]

    local t = table.remove(tracerPool)  -- reuse from pool if available
    if t then
        t.container.CFrame = CFrame.new(origin)
        t.a1.WorldPosition = origin
        t.a2.WorldPosition = endPos
        t.beam.Color       = ColorSequence.new(tracerColor)
        t.beam.Width0      = diameter*2.5; t.beam.Width1=diameter*2.5
        t.beam.Texture     = textureId;    t.beam.TextureSpeed=texSpeed
        t.beam.Transparency= tracerTransCache[20]
        t.beam.Enabled     = true
        t.created          = os.clock()
        t.duration         = duration
        t.fullyVisible     = false
    else
        local container=Instance.new("Part"); container.Name="cumyin_tracer"
        container.Anchored=true; container.CanCollide=false; container.CanQuery=false
        container.CastShadow=false; container.Transparency=1; container.Size=Vector3.new(0.01,0.01,0.01)
        container.CFrame=CFrame.new(origin); container.Parent=workspace
        local a1=Instance.new("Attachment",container); a1.WorldPosition=origin
        local a2=Instance.new("Attachment",container); a2.WorldPosition=endPos
        local beam=Instance.new("Beam",container)
        beam.Attachment0=a1; beam.Attachment1=a2
        beam.Color=ColorSequence.new(tracerColor)
        beam.Width0=diameter*2.5; beam.Width1=diameter*2.5
        beam.Texture=textureId; beam.TextureMode=Enum.TextureMode.Static
        beam.TextureLength=4; beam.TextureSpeed=texSpeed
        beam.Transparency=tracerTransCache[20]; beam.ZOffset=1
        beam.FaceCamera=true; beam.LightEmission=10; beam.LightInfluence=0
        t={container=container,a1=a1,a2=a2,beam=beam,created=os.clock(),duration=duration,fullyVisible=false}
    end
    table.insert(bulletTracersList,t)
end

-- Tracer fade loop
RunService.RenderStepped:Connect(function()
    if not (Toggles.TracerEnabled and Toggles.TracerEnabled.Value) then return end
    local now=os.clock()
    for i=#bulletTracersList,1,-1 do
        local t=bulletTracersList[i]; local passed=now-t.created
        if passed<0.5 then
            local pVal=1-(passed*2); local idx=math.clamp(math.floor(pVal*20+0.5),0,20)
            t.beam.Transparency=tracerTransCache[idx]
        elseif passed<t.duration then
            if not t.fullyVisible then t.beam.Transparency=tracerTransCache[0]; t.fullyVisible=true end
        elseif passed<t.duration+1 then
            t.fullyVisible=false; local pVal=passed-t.duration
            local idx=math.clamp(math.floor(pVal*20+0.5),0,20); t.beam.Transparency=tracerTransCache[idx]
        else
            t.beam.Enabled=false; table.insert(tracerPool,t); table.remove(bulletTracersList,i)
        end
    end
end)

