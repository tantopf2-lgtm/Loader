        if on and sp.Z > 0 then
            anyOnScreen = true
            minX = math.min(minX, sp.X)
            minY = math.min(minY, sp.Y)
            maxX = math.max(maxX, sp.X)
            maxY = math.max(maxY, sp.Y)
        end
    end
    
    if not anyOnScreen then
        hideESPBox(box)
        continue
    end
    
    -- Add padding
    minX = minX - 2
    minY = minY - 2
    maxX = maxX + 2
    maxY = maxY + 2
    
    local width = maxX - minX
    local height = maxY - minY
    local cx = (minX + maxX) / 2
    
    -- Visibility check
