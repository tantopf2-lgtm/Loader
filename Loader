    end

    -- Helper to create outline lines for a triangle
    local function createArrowOutlines()
        local lines = {}
        for i = 1, 3 do
            local line = Drawing.new("Line")
            line.Thickness = outlineThick
            line.Color = Color3.fromRGB(0, 0, 0)   -- black outline
            line.Visible = false
            lines[i] = line
