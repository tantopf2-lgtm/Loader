local function pushNotification(text)
    pcall(function() Library:Notify(text, 4) end)
end

local function playSound(idStr, pitch)
    pcall(function()
        local id = tostring(idStr):match("%d+") or ""
        if id == "" then return end
        local s = Instance.new("Sound"); s.SoundId="rbxassetid://"..id
        s.Volume=1; s.PlaybackSpeed=pitch or 1; s.Parent=workspace; s:Play()
        Debris:AddItem(s, 5)
    end)
end

