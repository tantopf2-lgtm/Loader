        arrow.PointA = pointA
        arrow.PointB = pointB
        arrow.PointC = pointC
        arrow.Visible = true

        -- Update outline lines (behind, thicker)
        if outlines then
            -- Edge AB
            outlines[1].From = pointA
            outlines[1].To = pointB
            outlines[1].Visible = true
            -- Edge BC
            outlines[2].From = pointB
            outlines[2].To = pointC
            outlines[2].Visible = true
            -- Edge CA
            outlines[3].From = pointC
            outlines[3].To = pointA
            outlines[3].Visible = true
        end
    end

    -- Cleanup arrows for players that no longer exist
    for player in pairs(arrowObjects) do
        if not player.Parent then
            if arrowObjects[player] then
                arrowObjects[player]:Remove()
                arrowObjects[player] = nil
            end
